# =====================================================
# Streamlit Secrets 設定ファイル（テンプレート）
# =====================================================
# 使い方:
#   このファイルを secrets.toml にコピーして、キーを入力してください
#   $ cp secrets.toml.example secrets.toml
#
# ⚠️ secrets.toml は .gitignore に追加してください（公開しないこと）
#
# Streamlit Cloud で公開する場合:
#   アプリの Settings > Secrets にこの内容を貼り付けてください
# =====================================================

# Google Gemini APIキー（無料）
# 取得: https://aistudio.google.com/apikey
GEMINI_API_KEY = "AIzaSy..."

# Anthropic Claude APIキー（有料・高精度）
# 取得: https://console.anthropic.com
# ANTHROPIC_API_KEY = "sk-ant-..."
